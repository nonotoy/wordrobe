{
  "expo": {
    "name": "Wordrobe",
    "slug": "wordrobe",
    "version": "0.1.0",
    "orientation": "portrait",
    "icon": "./assets/app-icon-1024.png",
    "userInterfaceStyle": "automatic",
    "splash": {
      "image": "./assets/app-icon-1024.png",
      "resizeMode": "contain",
      "backgroundColor": "#FF6600"
    },
    "assetBundlePatterns": [
      "**/*"
    ],
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.wordrobe.dictionary",
      "infoPlist": {
        "ITSAppUsesNonExemptEncryption": false
      }
    },
    "android": {
      "package": "com.wordrobe.dictionary",
      "adaptiveIcon": {
        "foregroundImage": "./assets/app-icon-1024.png",
        "backgroundColor": "#FF6600"
      }
    },
    "web": {},
    "extra": {
      "eas": {
        "projectId": "cd9155d3-8ba3-4724-b5d4-8983eb422097"
      }
    }
  }
}
