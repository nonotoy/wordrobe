  "sentences": [
    {
      "id": "s001",
      "sentence_primary": "Kamuy wen kur oka.",
      "translation": "悪い神がいる。",
      "source": "萱野茂 (1998)"
    },
    {
      "id": "s002",
      "sentence_primary": "Kamuy pirka kur ne.",
      "translation": "神は良い存在である。",
      "source": "田村すず子 (1996)"
    },
    {
      "id": "s003",
      "sentence_primary": "Pirka to ne.",
      "translation": "良い日だ。",
      "source": "中川裕 (1995)"
    },
    {
      "id": "s004",
      "sentence_primary": "Ku=siki pirka.",
      "translation": "私の目は良い。",
      "source": "田村すず子 (1996)"
    },
    {
      "id": "s005",
      "sentence_primary": "Mosir un kamuy.",
      "translation": "国の神。",
      "source": "萱野茂 (1998)"
    },
    {
      "id": "s006",
      "sentence_primary": "Tan kotan ta arpa.",
      "translation": "この村に行く。",
      "source": "田村すず子 (1996)"
    },
    {
      "id": "s007",
      "sentence_primary": "Utari opitta paye.",
      "translation": "仲間たちが行く。",
      "source": "田村すず子 (1996)"
    },
    {
      "id": "s008",
      "sentence_primary": "Cise ta ahun.",
      "translation": "家に入る。",
      "source": "田村すず子 (1996)"
    },
    {
      "id": "s009",
      "sentence_primary": "Pet sam ta an.",
      "translation": "川のそばにいる。",
      "source": "田村すず子 (1996)"
    },
    {
      "id": "s010",
      "sentence_primary": "Nupuri ta hopuni.",
      "translation": "山に登る。",
      "source": "田村すず子 (1996)"
    },
    {
      "id": "s011",
      "sentence_primary": "Wakka ku=iku.",
      "translation": "私は水を飲む。",
      "source": "田村すず子 (1996)"
